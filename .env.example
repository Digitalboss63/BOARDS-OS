# BOARDS-OS — Required Environment Variables
# Copy this to .env for local development. Never commit .env with real values.

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the API server listens on (set automatically by Railway/Replit)
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string
# Local: postgresql://postgres:password@localhost:5432/boards_os
# Railway: set in Railway Variables tab as DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/boards_os

# ─── Future: AI Provider (Phase 5) ────────────────────────────────────────────
# Anthropic API key — server-side ONLY, never expose to frontend
# ANTHROPIC_API_KEY=sk-ant-...

# AI model override (avoids hardcoding model names)
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Future: Auth (Phase 6) ───────────────────────────────────────────────────
# Admin token for protected routes
# ADMIN_TOKEN=

# Session secret for cookie-based auth (if added)
# SESSION_SECRET=
