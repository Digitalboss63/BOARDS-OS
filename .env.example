# BOARDS-OS — Required Environment Variables
# Copy this to .env for local development. Never commit .env with real values.

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/boards_os

# ─── Security ─────────────────────────────────────────────────────────────────
# Admin token — required for /api/system/* routes
# Generate: openssl rand -hex 32
ADMIN_TOKEN=

# ─── CORS (Production) ────────────────────────────────────────────────────────
# Primary app URL — used to restrict CORS in production
APP_URL=https://your-app.replit.app

# Additional allowed origins (comma-separated, optional)
# APP_ALLOWED_ORIGINS=https://admin.yourapp.com,https://app.yourapp.com

# ─── Future: AI Provider (Phase 6) ───────────────────────────────────────────
# Server-side ONLY — never expose to frontend
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5

# ─── Future: Auth (Phase 7) ───────────────────────────────────────────────────
# CLERK_SECRET_KEY=
# VITE_CLERK_PUBLISHABLE_KEY=   ← frontend only, safe as VITE_*
